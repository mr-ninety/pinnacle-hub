# =============================================================
# Unnnati – .htaccess
# Clean URLs, basic security, caching, no directory listing
# =============================================================

<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # 1. Remove .php extension from URLs (example: dashboard.php → /dashboard)
    RewriteCond %{THE_REQUEST} \s/+([^\s]*)\.php[\s?] [NC]
    RewriteRule ^ /%1 [R=301,L,NE]

    # 2. Internally map extensionless URLs back to .php files
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME}.php -f
    RewriteRule ^(.*)$ $1.php [L]

    # 3. Force trailing slash on directories (optional but cleaner)
    RewriteCond %{REQUEST_URI} /+[^\.]+$
    RewriteRule ^(.+[^/])$ %{REQUEST_URI}/ [R=301,L]
</IfModule>

# =============================================================
# Security headers & restrictions
# =============================================================

# Prevent directory listing
Options -Indexes

# Block access to sensitive files
<FilesMatch "\.(env|sql|ini|log|bak|dist|example|lock|md|gitignore|htaccess|yml|yaml)$">
    Order Allow,Deny
    Deny from all
</FilesMatch>

<Files ~ "^\.">
    Order Allow,Deny
    Deny from all
</Files>

# Basic XSS / clickjacking protection (most modern hosts support these)
<IfModule mod_headers.c>
    Header set X-Content-Type-Options "nosniff"
    Header set X-Frame-Options "SAMEORIGIN"
    Header set X-XSS-Protection "1; mode=block"
    Header set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# =============================================================
# Caching for static assets (good for performance on shared hosting)
# =============================================================

<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/jpg "access plus 1 month"
    ExpiresByType image/jpeg "access plus 1 month"
    ExpiresByType image/gif "access plus 1 month"
    ExpiresByType image/png "access plus 1 month"
    ExpiresByType text/css "access plus 1 week"
    ExpiresByType application/javascript "access plus 1 week"
    ExpiresByType image/x-icon "access plus 1 year"
    ExpiresDefault "access plus 2 days"
</IfModule>

# Compress text files
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript application/javascript application/json
</IfModule>